# Copy this file to .env before local use.
# The app can run without an API key by using local rules and knowledge-base retrieval.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
FLASK_SECRET_KEY=change-this-in-production
DATA_PATH=data/knowledge_base.xlsx
USCC_DATA_DIR=.uscc_scc_flask_data

# Upload and batch parsing limits.
MAX_UPLOAD_MB=512
MAX_BATCH_FILES=500
MAX_TEXT_CHARS_PER_FILE=500000
